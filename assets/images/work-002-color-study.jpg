<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="colorStudy" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#FFD700;stop-opacity:1" />
      <stop offset="25%" style="stop-color:#FF8C00;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#FF6347;stop-opacity:1" />
      <stop offset="75%" style="stop-color:#4B0082;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#191970;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="800" height="600" fill="url(#colorStudy)"/>
  
  <g transform="translate(50, 50)" fill="white" opacity="0.9">
    <text font-family="Arial, sans-serif" font-size="24" font-weight="bold" y="0">
      色彩研究 - 日落渐变
    </text>
    
    <g transform="translate(0, 50)">
      <text font-size="16" y="0">黄金时刻 #FFD700</text>
      <rect y="10" width="200" height="40" fill="#FFD700"/>
    </g>
    
    <g transform="translate(0, 140)">
      <text font-size="16" y="0">橙色黄昏 #FF8C00</text>
      <rect y="10" width="200" height="40" fill="#FF8C00"/>
    </g>
    
    <g transform="translate(0, 230)">
      <text font-size="16" y="0">红色过渡 #FF6347</text>
      <rect y="10" width="200" height="40" fill="#FF6347"/>
    </g>
    
    <g transform="translate(0, 320)">
      <text font-size="16" y="0">紫色暮光 #4B0082</text>
      <rect y="10" width="200" height="40" fill="#4B0082"/>
    </g>
    
    <g transform="translate(0, 410)">
      <text font-size="16" y="0">深蓝夜色 #191970</text>
      <rect y="10" width="200" height="40" fill="#191970"/>
    </g>
  </g>
</svg>
